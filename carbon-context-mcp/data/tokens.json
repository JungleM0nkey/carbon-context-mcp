{
  "spacing": [
    { "token": "$spacing-01", "rem": 0.125, "px": 2, "use": "Hairline insets" },
    { "token": "$spacing-02", "rem": 0.25, "px": 4, "use": "Tight icon/text gaps" },
    { "token": "$spacing-03", "rem": 0.5, "px": 8, "use": "Compact component padding" },
    { "token": "$spacing-04", "rem": 0.75, "px": 12, "use": "Small padding" },
    { "token": "$spacing-05", "rem": 1, "px": 16, "use": "Default gutter / component padding" },
    { "token": "$spacing-06", "rem": 1.5, "px": 24, "use": "Section spacing" },
    { "token": "$spacing-07", "rem": 2, "px": 32, "use": "Large component spacing" },
    { "token": "$spacing-08", "rem": 2.5, "px": 40, "use": "Layout spacing" },
    { "token": "$spacing-09", "rem": 3, "px": 48, "use": "Layout spacing" },
    { "token": "$spacing-10", "rem": 4, "px": 64, "use": "Large layout gaps" },
    { "token": "$spacing-11", "rem": 5, "px": 80, "use": "Large layout gaps" },
    { "token": "$spacing-12", "rem": 6, "px": 96, "use": "Page sectioning" },
    { "token": "$spacing-13", "rem": 10, "px": 160, "use": "Page-level whitespace" }
  ],
  "type": [
    { "token": "code-01", "px": 12, "lineHeight": 16, "weight": 400, "letterSpacing": "0.32px", "font": "IBM Plex Mono", "use": "Inline code" },
    { "token": "code-02", "px": 14, "lineHeight": 20, "weight": 400, "letterSpacing": "0.32px", "font": "IBM Plex Mono", "use": "Code blocks" },
    { "token": "label-01", "px": 12, "lineHeight": 16, "weight": 400, "letterSpacing": "0.32px", "use": "Field labels, captions" },
    { "token": "label-02", "px": 14, "lineHeight": 18, "weight": 400, "letterSpacing": "0.16px", "use": "Larger labels" },
    { "token": "helper-text-01", "px": 12, "lineHeight": 16, "weight": 400, "letterSpacing": "0.32px", "use": "Helper text under fields" },
    { "token": "body-compact-01", "px": 14, "lineHeight": 18, "weight": 400, "letterSpacing": "0.16px", "use": "Dense body" },
    { "token": "body-01", "px": 14, "lineHeight": 20, "weight": 400, "letterSpacing": "0.16px", "use": "Default body" },
    { "token": "body-02", "px": 16, "lineHeight": 24, "weight": 400, "letterSpacing": "0px", "use": "Comfortable body" },
    { "token": "heading-compact-01", "px": 14, "lineHeight": 18, "weight": 600, "letterSpacing": "0.16px", "use": "Dense headings" },
    { "token": "heading-01", "px": 14, "lineHeight": 20, "weight": 600, "letterSpacing": "0.16px", "use": "Small heading" },
    { "token": "heading-02", "px": 16, "lineHeight": 24, "weight": 600, "letterSpacing": "0px", "use": "Heading" },
    { "token": "heading-03", "px": 20, "lineHeight": 28, "weight": 400, "letterSpacing": "0px", "use": "Section heading" },
    { "token": "heading-04", "px": 28, "lineHeight": 36, "weight": 400, "letterSpacing": "0px", "use": "Large heading" },
    { "token": "heading-05", "px": 32, "lineHeight": 40, "weight": 400, "letterSpacing": "0px", "use": "Page title" },
    { "token": "heading-06", "px": 42, "lineHeight": 50, "weight": 300, "letterSpacing": "0px", "use": "Expressive heading" },
    { "token": "heading-07", "px": 54, "lineHeight": 64, "weight": 300, "letterSpacing": "0px", "use": "Display heading" }
  ],
  "typeSets": {
    "productive": "suffix -01; dense product UI; fixed heading sizes",
    "expressive": "suffix -02 and fluid-*; editorial/marketing; larger, responsive headings",
    "fluidTokens": ["fluid-heading-03", "fluid-heading-04", "fluid-heading-05", "fluid-heading-06", "fluid-display-01", "fluid-display-02", "fluid-display-03", "fluid-display-04", "fluid-paragraph-01", "fluid-quotation-01", "fluid-quotation-02"],
    "fontStacks": {
      "sans": "'IBM Plex Sans', 'Helvetica Neue', Arial, sans-serif",
      "mono": "'IBM Plex Mono', 'Menlo', 'DejaVu Sans Mono', Courier, monospace",
      "serif": "'IBM Plex Serif', 'Georgia', Times, serif"
    },
    "weights": { "light": 300, "regular": 400, "semibold": 600 }
  },
  "colorTokenGroups": [
    { "group": "background", "tokens": ["$background", "$background-hover", "$background-active", "$background-selected"], "purpose": "Page / primary surface" },
    { "group": "layer", "tokens": ["$layer-01", "$layer-02", "$layer-03", "$layer-hover-01", "$layer-active-01", "$layer-selected-01"], "purpose": "Stacked/elevated surfaces; nest by depth (this is how Carbon does depth — not shadows)" },
    { "group": "field", "tokens": ["$field-01", "$field-02"], "purpose": "Input backgrounds" },
    { "group": "border", "tokens": ["$border-subtle", "$border-strong", "$border-interactive", "$border-inverse"], "purpose": "Dividers, input borders" },
    { "group": "text", "tokens": ["$text-primary", "$text-secondary", "$text-placeholder", "$text-helper", "$text-on-color", "$text-disabled", "$text-error", "$text-inverse"], "purpose": "Type colors" },
    { "group": "link", "tokens": ["$link-primary", "$link-secondary", "$link-inverse", "$link-visited"], "purpose": "Links" },
    { "group": "icon", "tokens": ["$icon-primary", "$icon-secondary", "$icon-on-color", "$icon-disabled"], "purpose": "Icons" },
    { "group": "support", "tokens": ["$support-error", "$support-success", "$support-warning", "$support-info"], "purpose": "Status / notification" },
    { "group": "focus", "tokens": ["$focus", "$focus-inset", "$focus-inverse"], "purpose": "Keyboard focus ring — never remove" },
    { "group": "interactive", "tokens": ["$interactive", "$link-primary"], "purpose": "Primary accent (Blue 60 #0f62fe in White theme)" },
    { "group": "skeleton", "tokens": ["$skeleton-background", "$skeleton-element"], "purpose": "Loading placeholders" }
  ],
  "themes": [
    { "name": "white", "mode": "light", "background": "#ffffff" },
    { "name": "g10", "mode": "light", "background": "#f4f4f4" },
    { "name": "g90", "mode": "dark", "background": "#262626" },
    { "name": "g100", "mode": "dark", "background": "#161616" }
  ],
  "layeringModel": "$background -> $layer-01 -> $layer-02 -> $layer-03; pick layer token by nesting depth so surfaces stay distinguishable in every theme",
  "motion": {
    "modes": { "productive": "efficient, subtle — task moments", "expressive": "vibrant — significant moments" },
    "easing": [
      { "curve": "standard", "productive": "cubic-bezier(0.2, 0, 0.38, 0.9)", "expressive": "cubic-bezier(0.4, 0.14, 0.3, 1)" },
      { "curve": "entrance", "productive": "cubic-bezier(0, 0, 0.38, 0.9)", "expressive": "cubic-bezier(0, 0, 0.3, 1)" },
      { "curve": "exit", "productive": "cubic-bezier(0.2, 0, 1, 0.9)", "expressive": "cubic-bezier(0.4, 0.14, 1, 1)" }
    ],
    "duration": [
      { "token": "$duration-fast-01", "ms": 70, "use": "Micro (button, toggle)" },
      { "token": "$duration-fast-02", "ms": 110, "use": "Micro (fade)" },
      { "token": "$duration-moderate-01", "ms": 150, "use": "Small expansions" },
      { "token": "$duration-moderate-02", "ms": 240, "use": "Toasts, system comms" },
      { "token": "$duration-slow-01", "ms": 400, "use": "Large expansion, notifications" },
      { "token": "$duration-slow-02", "ms": 700, "use": "Background dimming" }
    ],
    "sassFn": "motion($name, $mode) -> cubic-bezier"
  },
  "grid": {
    "miniUnit": 8,
    "defaultGutterPx": 32,
    "gutterModes": { "wide": 32, "narrow": 16, "condensed": 1 },
    "aspectRatios": ["1:1", "2:1", "2:3", "3:2", "4:3", "16:9"],
    "react": "<Grid> + <Column sm={4} md={8} lg={16}> ; props condensed/narrow for tighter modes; Column must be a direct child of Grid",
    "breakpoints": [
      { "key": "sm", "px": 320, "rem": 20, "columns": 4, "marginPx": 0 },
      { "key": "md", "px": 672, "rem": 42, "columns": 8, "marginPx": 16 },
      { "key": "lg", "px": 1056, "rem": 66, "columns": 16, "marginPx": 16 },
      { "key": "xlg", "px": 1312, "rem": 82, "columns": 16, "marginPx": 16 },
      { "key": "max", "px": 1584, "rem": 99, "columns": 16, "marginPx": 24 }
    ]
  },
  "rules": {
    "core": "Emit tokens, never literals. Every spacing/color/type/motion value has a token; hardcoding px/hex breaks theming, dark mode, and responsiveness.",
    "sassUsage": "@use '@carbon/styles/scss/theme'; then theme.$text-primary (resolves to var(--cds-text-primary)). theme.get('token') for a raw value.",
    "cssVar": "--cds-<token>",
    "jsImport": "import { white, g100, spacing, blue50 } from '@carbon/elements';",
    "prefix": "cds (v11). bx is v10."
  }
}
